@model Eventra.Models.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Register";
}

@section Styles {
    <link rel="stylesheet" href="~/css/styleregister.css" asp-append-version="true" />
}

<main class="register-page">
    <div class="container register-wrapper">

        <section class="register-left">
            <p class="eyebrow">Join the Eventra community</p>
            <h1>Create a new account</h1>
            <p class="intro-text">
                Register to discover events, save your favorites, manage bookings and enjoy a more personalized Eventra experience.
            </p>

            <div class="benefits-box">
                <h3>With an Eventra account you can:</h3>
                <ul>
                    <li>Browse and save favorite events</li>
                    <li>Manage your registrations in one place</li>
                    <li>Receive event recommendations</li>
                    <li>Build your personal event profile</li>
                </ul>
            </div>
        </section>

        <section class="register-card">
            <h2>Sign Up</h2>
            <p class="card-subtitle">Create your account in just a few steps</p>

            <form asp-action="Register" method="post" class="register-form">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="form-row">
                    <div class="input-group">
                        <label asp-for="FirstName"></label>
                        <input asp-for="FirstName" placeholder="Enter your first name" />
                        <span asp-validation-for="FirstName" class="text-danger"></span>
                    </div>

                    <div class="input-group">
                        <label asp-for="LastName"></label>
                        <input asp-for="LastName" placeholder="Enter your last name" />
                        <span asp-validation-for="LastName" class="text-danger"></span>
                    </div>
                </div>

                <div class="input-group">
                    <label asp-for="Email"></label>
                    <input asp-for="Email" placeholder="you@example.com" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="input-group">
                    <label asp-for="Username"></label>
                    <input asp-for="Username" placeholder="Choose a username" />
                    <span asp-validation-for="Username" class="text-danger"></span>
                </div>

                <div class="input-group">
                    <label asp-for="PhoneNumber"></label>
                    <input asp-for="PhoneNumber" placeholder="+40 712 345 678" />
                    <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                </div>

                <div class="form-row">
                    <div class="input-group">
                        <label asp-for="Password"></label>
                        <input asp-for="Password" placeholder="Create a password" />
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <div class="input-group">
                        <label asp-for="ConfirmPassword"></label>
                        <input asp-for="ConfirmPassword" placeholder="Confirm password" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    </div>
                </div>

                <div class="input-group">
                    <label asp-for="Role"></label>
                    <select asp-for="Role">
                        <option value="">Select account type</option>
                        <option value="Guest">Guest</option>
                        <option value="Organizer">Organizer</option>
                    </select>
                    <span asp-validation-for="Role" class="text-danger"></span>
                </div>

                <button type="submit" class="register-btn">Create Account</button>
            </form>

            <div class="divider">
                <span>or</span>
            </div>

            <button class="secondary-btn" type="button">Continue with Google</button>

            <p class="signin-text">
                Already have an account?
                <a asp-controller="Account" asp-action="SignIn">Sign in here</a>
            </p>
        </section>
    </div>
</main>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}