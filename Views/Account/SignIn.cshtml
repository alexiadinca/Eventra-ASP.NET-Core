@model Eventra.Models.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Sign In";
}

@section Styles {
    <link rel="stylesheet" href="~/css/stylesignin.css" asp-append-version="true" />
}

<main class="signin-page">
    <div class="container signin-wrapper">

        <section class="signin-left">
            <p class="eyebrow">Welcome back to Eventra</p>
            <h1>Sign in to your account</h1>
            <p class="intro-text">
                Access your profile, explore saved events, manage registrations and continue discovering elegant experiences near you.
            </p>

            <div class="benefits-box">
                <h3>Why sign in?</h3>
                <ul>
                    <li>Save your favorite events</li>
                    <li>Manage event registrations</li>
                    <li>Access your profile and tickets</li>
                    <li>Stay updated with personalized recommendations</li>
                </ul>
            </div>
        </section>

        <section class="signin-card">
            <h2>Sign In</h2>
            <p class="card-subtitle">Enter your details to continue</p>

            <form asp-action="SignIn" method="post" class="signin-form">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="input-group">
                    <label asp-for="EmailOrUsername">Email or Username</label>
                    <input asp-for="EmailOrUsername" placeholder="you@example.com or username" />
                    <span asp-validation-for="EmailOrUsername" class="text-danger"></span>
                </div>

                <div class="input-group">
                    <label asp-for="Password"></label>
                    <input asp-for="Password" placeholder="Enter your password" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <div class="form-options">
                    <label class="remember-me">
                        <input asp-for="RememberMe" />
                        <span>Remember me</span>
                    </label>
                </div>

                <button type="submit" class="signin-btn">Sign In</button>
            </form>

            <div class="divider">
                <span>or</span>
            </div>

            <button class="secondary-btn" type="button">Continue with Google</button>

            <p class="register-text">
                Don’t have an account?
                <a asp-controller="Account" asp-action="Register">Create one here</a>
            </p>
        </section>
    </div>
</main>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}