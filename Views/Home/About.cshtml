@{
    ViewData["Title"] = "About Us";
}

@section Styles {
    <link rel="stylesheet" href="~/css/styleabout.css" asp-append-version="true" />
}

<main class="about-page">
    <section class="about-hero">
        <div class="container">
            <p class="eyebrow">About the platform</p>
            <h1>About Eventra</h1>
            <p class="intro-text">
                Eventra is a modern web platform designed to help users discover events,
                connect with organizers, and explore experiences happening around them.
            </p>
        </div>
    </section>

    <section class="about-project">
        <div class="container about-grid">
            <div class="about-text">
                <h2>University Project</h2>
                <p>Eventra was developed as a university project for the course <strong>Web Applications Design</strong>.</p>
                <p>The goal of the project is to design and implement a complete event management platform where users can create accounts, browse events, register for experiences and organizers can publish and manage their own events.</p>
                <ul>
                    <li>HTML5 and semantic web structure</li>
                    <li>CSS layout and responsive design</li>
                    <li>JavaScript front-end logic</li>
                    <li>UI/UX design principles</li>
                    <li>Web application architecture</li>
                </ul>
            </div>

            <div class="about-card">
                <h3>Project Information</h3>
                <p><strong>Project Name:</strong> Eventra</p>
                <p><strong>Type:</strong> Web Application</p>
                <p><strong>Purpose:</strong> Event discovery and management platform</p>
                <p><strong>Technology:</strong> ASP.NET Core MVC</p>
                <p><strong>Project Type:</strong> University Project</p>
            </div>
        </div>
    </section>

    <section class="about-location">
        <div class="container">
            <h2>Project Location</h2>
            <p class="location-text">
                This project was developed within the <strong>Faculty of Automation, Computers and Electronics</strong>, University of Craiova.
            </p>
            <div class="map-wrapper">
                <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2855.0574175413244!2d23.832505176916086!3d44.30877010978378!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x4752d702cd0f3173%3A0xb159446a3e899375!2sFacultatea%20de%20Automatic%C4%83%20%C8%99i%20Electronic%C4%83!5e0!3m2!1sro!2sro!4v1772987749903!5m2!1sro!2sro"
                        width="100%" height="420" style="border:0;" allowfullscreen="" loading="lazy"></iframe>
            </div>
        </div>
    </section>
</main>